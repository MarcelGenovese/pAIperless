# Database
DATABASE_URL="file:./storage/database/paiperless.db"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Application URL (used for webhooks and OAuth)
# Development: http://localhost:3000
# Production: http://your-domain:3002 or https://your-domain
NEXTAUTH_URL="http://localhost:3002"

# Node Environment
NODE_ENV="development"

# FTP Server Configuration (Optional - Usually not needed!)
# The FTP server automatically uses the IP address that clients connect to.
# This works for any network configuration without manual setup.
#
# Only set FTP_PASV_URL if you're behind NAT/port forwarding:
# Example: FTP_PASV_URL="your-public-ip"
# FTP_PASV_URL=""
