# Database
DATABASE_URL="file:./storage/database/paiperless.db"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Application URL (used for webhooks and OAuth)
# Development: http://localhost:3000
# Production: http://your-domain:3002 or https://your-domain
NEXTAUTH_URL="http://localhost:3002"

# Node Environment
NODE_ENV="development"

# FTP Server Configuration
# Set this to your server's external IP address or hostname
# This is required for FTP passive mode to work correctly
# Example for local network: 192.168.1.100
# Example for internet: your-public-ip or domain.com
FTP_PASV_URL="192.168.1.100"
