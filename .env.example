# Database
DATABASE_URL="file:./storage/database/paiperless.db"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Application URL (used for webhooks and OAuth)
# Development: http://localhost:3000
# Production: http://your-domain:3002 or https://your-domain
NEXTAUTH_URL="http://localhost:3002"

# Node Environment
NODE_ENV="development"

# FTP Server Configuration (Optional)
# pAIperless will auto-detect the PASV URL from:
# 1. Your Paperless-NGX URL hostname
# 2. Your server's primary network interface IP
#
# Only set this if auto-detection fails or you need a specific IP/hostname
# Example for local network: FTP_PASV_URL="192.168.1.100"
# Example for internet: FTP_PASV_URL="your-public-ip"
# FTP_PASV_URL="192.168.1.100"
